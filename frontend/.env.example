# =============================================================================
# HELIX.GP Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# All variables prefixed with VITE_ are exposed to the client-side code.
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------

# Backend API URL (required for production)
# Example: https://api.helix-gp.example.com
VITE_API_URL=https://api.helix-gp.example.com

# API path prefix (usually /api)
VITE_API_PATH=/api

# API host (optional, used for cross-origin requests)
VITE_API_HOST=

# API prefix path (optional)
VITE_API_PREFIX_PATH=

# WebSocket API URL (required if using WebSocket features)
# Example: wss://api.helix-gp.example.com
VITE_WS_API_URL=wss://api.helix-gp.example.com

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Unique application identifier
VITE_APP_ID=helix-gp

# Base path for the SPA (use "/" for root, or "/subpath" for subdirectory)
VITE_APP_BASE_PATH=/

# Application title (shown in browser tab)
VITE_APP_TITLE=Helix.GP

# Favicon paths (relative to public folder)
VITE_APP_FAVICON_LIGHT=/favicon-light.svg
VITE_APP_FAVICON_DARK=/favicon-dark.svg

# -----------------------------------------------------------------------------
# Deployment Information (optional)
# -----------------------------------------------------------------------------

# Deploy username (optional, for display purposes)
VITE_APP_DEPLOY_USERNAME=

# Deploy app name (optional, for display purposes)
VITE_APP_DEPLOY_APPNAME=

# Custom domain (optional)
VITE_APP_DEPLOY_CUSTOM_DOMAIN=

# -----------------------------------------------------------------------------
# Stack Auth Configuration (required for authentication features)
# -----------------------------------------------------------------------------
# Get these values from your Stack Auth dashboard at https://stack-auth.com

# Stack Auth Project ID
VITE_STACK_AUTH_PROJECT_ID=

# Stack Auth Publishable Client Key (starts with pk_)
VITE_STACK_AUTH_PUBLISHABLE_KEY=

# Stack Auth JWKS URL for token verification
VITE_STACK_AUTH_JWKS_URL=

# Auth handler URL path (default: auth)
VITE_STACK_AUTH_HANDLER_URL=auth
